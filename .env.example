QOBUZ_EMAIL=your@email.com
QOBUZ_PASSWORD=yourpassword

# If email/password login stops working (Qobuz periodically changes their auth flow),
# you can provide a token directly instead. To get one:
#   1. Log in at play.qobuz.com in your browser
#   2. Open DevTools (F12) -> Network tab -> filter for "user/login"
#   3. Click the request -> Response tab -> copy the value of "user_auth_token"
#   4. Paste it below. Tokens expire periodically so you may need to refresh it.
# QOBUZ_AUTH_TOKEN=your_token_here
